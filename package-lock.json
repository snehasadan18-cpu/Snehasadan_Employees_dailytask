const fs = require('fs');
const path = require('path');
const express = require('express');
const bcrypt = require('bcryptjs');
const jwt = require('jsonwebtoken');
const helmet = require('helmet');
const Database = require('better-sqlite3');

const PORT = process.env.PORT || 3000;
const NODE_ENV = process.env.NODE_ENV || 'development';
const JWT_SECRET = process.env.JWT_SECRET || 'change-this-in-production';
const defaultDataDir = path.join(__dirname, 'data');
const DB_PATH = process.env.DB_PATH || path.join(defaultDataDir, 'staffscheduler.db');
const app = express();

const dbDir = path.dirname(DB_PATH);
if (!fs.existsSync(dbDir)) fs.mkdirSync(dbDir, { recursive: true });
const db = new Database(DB_PATH);
db.pragma('journal_mode = WAL');

db.exec(`
CREATE TABLE IF NOT EXISTS users (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  employee_id TEXT UNIQUE NOT NULL,
  name TEXT NOT NULL,
  email TEXT UNIQUE NOT NULL,
  password_hash TEXT NOT NULL,
  role TEXT NOT NULL CHECK(role IN ('Admin','Employee')),
  active INTEGER NOT NULL DEFAULT 1,
  created_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE IF NOT EXISTS schedules (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  user_id INTEGER NOT NULL UNIQUE,
  week_start TEXT NOT NULL,
  month TEXT NOT NULL,
  week_range TEXT NOT NULL,
  mon TEXT NOT NULL DEFAULT 'Work',
  tue TEXT NOT NULL DEFAULT 'Work',
  wed TEXT NOT NULL DEFAULT 'Work',
  thu TEXT NOT NULL DEFAULT 'Work',
  fri TEXT NOT NULL DEFAULT 'Work',
  sat TEXT NOT NULL DEFAULT 'Work',
  updated_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP,
  FOREIGN KEY(user_id) REFERENCES users(id) ON DELETE CASCADE
);

CREATE TABLE IF NOT EXISTS leave_requests (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  user_id INTEGER NOT NULL,
  leave_type TEXT NOT NULL,
  start_date TEXT NOT NULL,
  end_date TEXT NOT NULL,
  reason TEXT DEFAULT '',
  status TEXT NOT NULL DEFAULT 'Pending' CHECK(status IN ('Pending','Approved','Rejected')),
  reviewed_by INTEGER,
  reviewed_at TEXT,
  created_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP,
  FOREIGN KEY(user_id) REFERENCES users(id) ON DELETE CASCADE,
  FOREIGN KEY(reviewed_by) REFERENCES users(id) ON DELETE SET NULL
);
`);

function seedDefaults() {
  const count = db.prepare('SELECT COUNT(*) AS count FROM users').get().count;
  if (count > 0) return;
  const insert = db.prepare('INSERT INTO users (employee_id, name, email, password_hash, role) VALUES (?, ?, ?, ?, ?)');
  insert.run('ADMIN', 'Admin User', 'admin@company.com', bcrypt.hashSync('admin123', 10), 'Admin');
  insert.run('E001', 'Employee 1', 'employee1@company.com', bcrypt.hashSync('pass123', 10), 'Employee');
  insert.run('E002', 'Employee 2', 'employee2@company.com', bcrypt.hashSync('pass123', 10), 'Employee');
}
seedDefaults();

app.set('trust proxy', 1);
app.use(helmet({ contentSecurityPolicy: false, crossOriginEmbedderPolicy: false }));
app.use(express.json());
app.use(express.static(path.join(__dirname, 'public')));

function currentWeekInfo() {
  const now = new Date();
  const jsDay = now.getDay();
  const diffToMonday = jsDay === 0 ? -6 : 1 - jsDay;
  const monday = new Date(now);
  monday.setHours(0, 0, 0, 0);
  monday.setDate(now.getDate() + diffToMonday);
  const saturday = new Date(monday);
  saturday.setDate(monday.getDate() + 5);
  const fmt = (date) => date.toLocaleDateString(undefined, { day: '2-digit', month: 'short' });
  return {
    weekStart: monday.toISOString().slice(0, 10),
    month: monday.toLocaleDateString(undefined, { month: 'long' }),
    weekRange: `${fmt(monday)} - ${fmt(saturday)}`,
    year: monday.getFullYear()
  };
}

function mapUser(row) {
  if (!row) return null;
  return {
    id: row.id,
    employeeId: row.employee_id,
    name: row.name,
    email: row.email,
    role: row.role,
    active: !!row.active,
    createdAt: row.created_at
  };
}

function authRequired(req, res, next) {
  const header = req.headers.authorization || '';
  const token = header.startsWith('Bearer ') ? header.slice(7) : null;
  if (!token) return res.status(401).json({ error: 'Authentication required' });
  try {
    const decoded = jwt.verify(token, JWT_SECRET);
    const user = db.prepare('SELECT * FROM users WHERE id = ? AND active = 1').get(decoded.userId);
    if (!user) return res.status(401).json({ error: 'Invalid session' });
    req.user = user;
    next();
  } catch (error) {
    return res.status(401).json({ error: 'Invalid or expired token' });
  }
}

function adminOnly(req, res, next) {
  if (req.user.role !== 'Admin') return res.status(403).json({ error: 'Admin access required' });
  next();
}

app.post('/api/auth/login', (req, res) => {
  const login = String(req.body.login || '').trim();
  const password = String(req.body.password || '');
  const user = db.prepare('SELECT * FROM users WHERE (LOWER(employee_id) = LOWER(?) OR LOWER(email) = LOWER(?)) AND active = 1').get(login, login);
  if (!user || !bcrypt.compareSync(password, user.password_hash)) {
    return res.status(401).json({ error: 'Invalid credentials' });
  }
  const token = jwt.sign({ userId: user.id, role: user.role }, JWT_SECRET, { expiresIn: '12h' });
  res.json({ token, user: mapUser(user) });
});

app.get('/api/auth/me', authRequired, (req, res) => {
  res.json({ user: mapUser(req.user) });
});

app.get('/api/dashboard/summary', authRequired, (req, res) => {
  const week = currentWeekInfo();
  const pendingCount = req.user.role === 'Admin'
    ? db.prepare("SELECT COUNT(*) AS count FROM leave_requests WHERE status = 'Pending'").get().count
    : db.prepare("SELECT COUNT(*) AS count FROM leave_requests WHERE user_id = ? AND status = 'Pending'").get(req.user.id).count;
  const employeeCount = req.user.role === 'Admin'
    ? db.prepare("SELECT COUNT(*) AS count FROM users WHERE role = 'Employee' AND active = 1").get().count
    : null;
  res.json({ week, pendingCount, employeeCount, role: req.user.role });
});

app.get('/api/schedules/me', authRequired, (req, res) => {
  const week = currentWeekInfo();
  const row = db.prepare('SELECT * FROM schedules WHERE user_id = ?').get(req.user.id);
  res.json({
    schedule: row || {
      user_id: req.user.id,
      week_start: week.weekStart,
      month: week.month,
      week_range: week.weekRange,
      mon: 'Work', tue: 'Work', wed: 'Work', thu: 'Work', fri: 'Work', sat: 'Work'
    },
    week
  });
});

app.put('/api/schedules/me', authRequired, (req, res) => {
  const week = currentWeekInfo();
  const body = req.body || {};
  const payload = {
    mon: String(body.mon || 'Work').trim() || 'Work',
    tue: String(body.tue || 'Work').trim() || 'Work',
    wed: String(body.wed || 'Work').trim() || 'Work',
    thu: String(body.thu || 'Work').trim() || 'Work',
    fri: String(body.fri || 'Work').trim() || 'Work',
    sat: String(body.sat || 'Work').trim() || 'Work'
  };
  const exists = db.prepare('SELECT id FROM schedules WHERE user_id = ?').get(req.user.id);
  if (exists) {
    db.prepare(`UPDATE schedules SET week_start = ?, month = ?, week_range = ?, mon = ?, tue = ?, wed = ?, thu = ?, fri = ?, sat = ?, updated_at = CURRENT_TIMESTAMP WHERE user_id = ?`).run(
      week.weekStart, week.month, week.weekRange, payload.mon, payload.tue, payload.wed, payload.thu, payload.fri, payload.sat, req.user.id
    );
  } else {
    db.prepare(`INSERT INTO schedules (user_id, week_start, month, week_range, mon, tue, wed, thu, fri, sat) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`).run(
      req.user.id, week.weekStart, week.month, week.weekRange, payload.mon, payload.tue, payload.wed, payload.thu, payload.fri, payload.sat
    );
  }
  res.json({ success: true });
});

app.post('/api/leaves', authRequired, (req, res) => {
  const leaveType = String(req.body.leaveType || '').trim();
  const startDate = String(req.body.startDate || '').trim();
  const endDate = String(req.body.endDate || '').trim();
  const reason = String(req.body.reason || '').trim();
  if (!leaveType || !startDate || !endDate) {
    return res.status(400).json({ error: 'Leave type, start date, and end date are required' });
  }
  db.prepare('INSERT INTO leave_requests (user_id, leave_type, start_date, end_date, reason) VALUES (?, ?, ?, ?, ?)').run(
    req.user.id, leaveType, startDate, endDate, reason
  );
  res.json({ success: true });
});

app.get('/api/leaves/me', authRequired, (req, res) => {
  const rows = db.prepare('SELECT id, leave_type AS leaveType, start_date AS startDate, end_date AS endDate, reason, status, created_at AS createdAt FROM leave_requests WHERE user_id = ? ORDER BY id DESC').all(req.user.id);
  res.json({ items: rows });
});

app.get('/api/admin/users', authRequired, adminOnly, (req, res) => {
  const rows = db.prepare("SELECT * FROM users WHERE role = 'Employee' ORDER BY id DESC").all();
  res.json({ items: rows.map(mapUser) });
});

app.post('/api/admin/users', authRequired, adminOnly, (req, res) => {
  const employeeId = String(req.body.employeeId || '').trim().toUpperCase();
  const name = String(req.body.name || '').trim();
  const email = String(req.body.email || '').trim().toLowerCase();
  const password = String(req.body.password || '').trim();
  if (!employeeId || !name || !email || !password) {
    return res.status(400).json({ error: 'All employee fields are required' });
  }
  const duplicate = db.prepare('SELECT id FROM users WHERE employee_id = ? OR email = ?').get(employeeId, email);
  if (duplicate) return res.status(409).json({ error: 'Employee ID or email already exists' });
  const result = db.prepare('INSERT INTO users (employee_id, name, email, password_hash, role) VALUES (?, ?, ?, ?, ?)').run(
    employeeId, name, email, bcrypt.hashSync(password, 10), 'Employee'
  );
  const user = db.prepare('SELECT * FROM users WHERE id = ?').get(result.lastInsertRowid);
  res.status(201).json({ item: mapUser(user) });
});

app.put('/api/admin/users/:id', authRequired, adminOnly, (req, res) => {
  const id = Number(req.params.id);
  const existing = db.prepare("SELECT * FROM users WHERE id = ? AND role = 'Employee'").get(id);
  if (!existing) return res.status(404).json({ error: 'Employee not found' });
  const employeeId = String(req.body.employeeId || existing.employee_id).trim().toUpperCase();
  const name = String(req.body.name || existing.name).trim();
  const email = String(req.body.email || existing.email).trim().toLowerCase();
  const password = String(req.body.password || '').trim();
  const duplicate = db.prepare('SELECT id FROM users WHERE (employee_id = ? OR email = ?) AND id != ?').get(employeeId, email, id);
  if (duplicate) return res.status(409).json({ error: 'Employee ID or email already exists' });
  if (password) {
    db.prepare('UPDATE users SET employee_id = ?, name = ?, email = ?, password_hash = ? WHERE id = ?').run(
      employeeId, name, email, bcrypt.hashSync(password, 10), id
    );
  } else {
    db.prepare('UPDATE users SET employee_id = ?, name = ?, email = ? WHERE id = ?').run(employeeId, name, email, id);
  }
  const user = db.prepare('SELECT * FROM users WHERE id = ?').get(id);
  res.json({ item: mapUser(user) });
});

app.post('/api/admin/users/:id/reset-password', authRequired, adminOnly, (req, res) => {
  const id = Number(req.params.id);
  const existing = db.prepare("SELECT * FROM users WHERE id = ? AND role = 'Employee'").get(id);
  if (!existing) return res.status(404).json({ error: 'Employee not found' });
  const newPassword = String(req.body.password || 'pass123').trim() || 'pass123';
  db.prepare('UPDATE users SET password_hash = ? WHERE id = ?').run(bcrypt.hashSync(newPassword, 10), id);
  res.json({ success: true, password: newPassword });
});

app.delete('/api/admin/users/:id', authRequired, adminOnly, (req, res) => {
  const id = Number(req.params.id);
  const existing = db.prepare("SELECT * FROM users WHERE id = ? AND role = 'Employee'").get(id);
  if (!existing) return res.status(404).json({ error: 'Employee not found' });
  db.prepare('DELETE FROM users WHERE id = ?').run(id);
  db.prepare('DELETE FROM schedules WHERE user_id = ?').run(id);
  db.prepare('DELETE FROM leave_requests WHERE user_id = ?').run(id);
  res.json({ success: true });
});

app.get('/api/admin/leaves', authRequired, adminOnly, (req, res) => {
  const rows = db.prepare(`
    SELECT lr.id, u.employee_id AS employeeId, u.name AS employeeName, lr.leave_type AS leaveType,
           lr.start_date AS startDate, lr.end_date AS endDate, lr.reason, lr.status,
           lr.created_at AS createdAt, reviewer.name AS reviewedBy, lr.reviewed_at AS reviewedAt
    FROM leave_requests lr
    JOIN users u ON u.id = lr.user_id
    LEFT JOIN users reviewer ON reviewer.id = lr.reviewed_by
    ORDER BY lr.id DESC
  `).all();
  res.json({ items: rows });
});

app.patch('/api/admin/leaves/:id/status', authRequired, adminOnly, (req, res) => {
  const id = Number(req.params.id);
  const status = String(req.body.status || '').trim();
  if (!['Approved', 'Rejected'].includes(status)) {
    return res.status(400).json({ error: 'Invalid leave status' });
  }
  const existing = db.prepare('SELECT id FROM leave_requests WHERE id = ?').get(id);
  if (!existing) return res.status(404).json({ error: 'Leave request not found' });
  db.prepare('UPDATE leave_requests SET status = ?, reviewed_by = ?, reviewed_at = CURRENT_TIMESTAMP WHERE id = ?').run(status, req.user.id, id);
  res.json({ success: true });
});

app.get('/api/admin/schedules', authRequired, adminOnly, (req, res) => {
  const rows = db.prepare(`
    SELECT s.id, u.employee_id AS employeeId, u.name AS employeeName, s.week_start AS weekStart,
           s.month, s.week_range AS weekRange, s.mon, s.tue, s.wed, s.thu, s.fri, s.sat, s.updated_at AS updatedAt
    FROM schedules s
    JOIN users u ON u.id = s.user_id
    ORDER BY u.name ASC
  `).all();
  res.json({ items: rows });
});

app.get('/healthz', (req, res) => {
  res.json({ status: 'ok', environment: NODE_ENV, database: path.basename(DB_PATH) });
});

app.get('*', (req, res) => {
  res.sendFile(path.join(__dirname, 'public', 'index.html'));
});

const server = app.listen(PORT, () => {
  console.log(`Staff Scheduler server running on http://localhost:${PORT}`);
});

function shutdown(signal) {
  console.log(`${signal} received, shutting down gracefully`);
  server.close(() => {
    db.close();
    process.exit(0);
  });
}

process.on('SIGINT', () => shutdown('SIGINT'));
process.on('SIGTERM', () => shutdown('SIGTERM'));
